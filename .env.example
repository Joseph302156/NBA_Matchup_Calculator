# Copy this file to .env and paste your OpenAI API key.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# Optional: Postgres (e.g. Supabase) for per-date prediction cache — fast first loads.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# PREDICTIONS_DB_MAX_AGE_SECONDS=7200   # optional: ignore DB row older than this (fallback to live NBA fetch)
# WARM_CACHE_DAYS_AHEAD=14            # today .. today+N warmed by cron/script
# CRON_SECRET=long-random-string      # Bearer token for POST /internal/refresh-predictions-cache

# Copy this file to .env and paste your OpenAI API key.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# Optional: Postgres (e.g. Supabase) for per-date prediction cache — fast first loads.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# PREDICTIONS_DB_MAX_AGE_SECONDS=7200   # optional: ignore DB row older than this (fallback to live NBA fetch)
# WARM_CACHE_DAYS_AHEAD=7             # today .. today+N warmed by cron/script
# WARM_CACHE_PAUSE_SECONDS=8         # pause between dates (easier on NBA API + DNS)
# WARM_DATE_MAX_ATTEMPTS=3           # per-date retries on transient NBA timeouts
# WARM_CIJOB_NOFAIL=1                # warm script exits 0 even if dates failed (e.g. GitHub Actions)
# PIPELINE_PARALLEL_WORKERS=1        # during warm: sequential NBA = fewer timeouts
# NBA_STATS_TIMEOUT_SECONDS=120       # longer stats.nba.com reads (GitHub Actions sets CI auto 90s floor)
# CRON_SECRET=long-random-string      # Bearer token for POST /internal/refresh-predictions-cache
